# Stratum - Environment Variables
# Copy to .env.local and fill in your values

# Phase 1 foundation
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stratum
AUTH_SECRET=replace_me_with_a_long_random_secret
AUTH_GOOGLE_ID=replace_me_with_google_client_id
AUTH_GOOGLE_SECRET=replace_me_with_google_client_secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional in Phase 1; required when Phase 2 capture writes raw snapshots
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# STRATUM_S3_BUCKET=
# STRATUM_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Required once structured analysis is exercised
# GEMINI_API_KEY=
