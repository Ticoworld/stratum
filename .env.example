# Stratum - Environment Variables
# Copy to .env.local and fill in your values.
#
# Required for production/runtime:
# - DATABASE_URL
# - AUTH_SECRET
# - AUTH_GOOGLE_ID
# - AUTH_GOOGLE_SECRET
#
# Optional runtime settings:
# - NEXT_PUBLIC_SITE_URL
# - GEMINI_API_KEY
# - STRATUM_CACHE_TTL_HOURS
# - CRON_SECRET or STRATUM_SCHEDULED_CRON_SECRET
# - STRATUM_SCHEDULED_CRON_LIMIT
# - AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, STRATUM_S3_BUCKET
#
# Test/dev-only:
# - STRATUM_ENABLE_TEST_ROUTES
# - STRATUM_E2E_MODE
# - STRATUM_E2E_NO_MATCH_QUERY
# - STRATUM_E2E_PROVIDER_FAILURE_QUERY
# - STRATUM_E2E_THROW_QUERY

# Production/runtime
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stratum
AUTH_SECRET=replace_me_with_a_long_random_secret
AUTH_GOOGLE_ID=replace_me_with_google_client_id
AUTH_GOOGLE_SECRET=replace_me_with_google_client_secret
# Recommended everywhere. On Vercel, this can be omitted if System Environment Variables
# are exposed and you want to fall back to the generated deployment URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional runtime / reserved for later storage work
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# STRATUM_S3_BUCKET=

# Optional runtime
# GEMINI_API_KEY=
# STRATUM_CACHE_TTL_HOURS=24
# CRON_SECRET=
# STRATUM_SCHEDULED_CRON_SECRET=
# STRATUM_SCHEDULED_CRON_LIMIT=25

# Test / preview only
# STRATUM_ENABLE_TEST_ROUTES=1
# STRATUM_E2E_MODE=1
# STRATUM_E2E_NO_MATCH_QUERY=
# STRATUM_E2E_PROVIDER_FAILURE_QUERY=
# STRATUM_E2E_THROW_QUERY=
